# pretix API URL (without trailing slash)
NEXT_PUBLIC_PRETIX_URL=https://pretix.yadawi.com

# pretix API Token (from pretix Account → Settings → API)
PRETIX_API_TOKEN=your_api_token_here

# Webhook secret (for verifying incoming webhooks)
PRETIX_WEBHOOK_SECRET=your_webhook_secret_here

# Chatwoot webhook URL (optional - for WhatsApp notifications)
# Get this from your Chatwoot inbox settings
CHATWOOT_WEBHOOK_URL=

# Next.js config
NEXT_PUBLIC_APP_URL=https://yadawi.com
