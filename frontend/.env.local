# pretix API URL (local Docker)
# Using 127.0.0.1 for fixed routing to the Docker container on VPS
NEXT_PUBLIC_PRETIX_URL=http://localhost:8000

# pretix API Token
PRETIX_API_TOKEN=3ll9f5237hcv96ioakrebef35qvl7qvuurfp3ih46oldfc5i9abmrkdceirozhsz
PRETIX_SA_API_TOKEN=SA_3ll9f5237hcv96ioakrebef35qvl7qvuurfp3ih46oldfc5i9abmrkdceirozhsz

# Webhook secret
PRETIX_WEBHOOK_SECRET=dev-webhook-secret

# Chatwoot webhook URL (optional)
