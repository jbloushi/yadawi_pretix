# Default locale
NEXT_PUBLIC_DEFAULT_LOCALE=ar

# Currency
NEXT_PUBLIC_DEFAULT_CURRENCY=KWD

# NextAuth
NEXTAUTH_SECRET=yadawi-admin-secret-key-change-in-production
